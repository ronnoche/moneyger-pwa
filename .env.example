# ------------------------------------------------------------------------------
# CLIENT-SAFE (browser-readable, shipped inside the JS bundle).
# Only variables prefixed with VITE_ are exposed to the client by Vite.
# NEVER put secrets here.
# ------------------------------------------------------------------------------

VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com


# ------------------------------------------------------------------------------
# SERVER-ONLY (Netlify functions). Not exposed to the browser.
# Set these in the Netlify dashboard and in a local `.env` (gitignored).
# ------------------------------------------------------------------------------

GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

APPS_SCRIPT_URL=https://script.google.com/macros/s/your-app-script-id/exec
APPS_SCRIPT_SECRET=your-shared-apps-script-secret

# Optional, comma-separated lowercase emails allowed to sync.
# Leave empty to allow any verified Google account that completed sign-in.
GOOGLE_ALLOWED_EMAILS=
